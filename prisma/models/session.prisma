enum GameSessionVisibility {
  PUBLIC
  FRIENDS_ONLY
  INVITE_CODE
}

model GameSession {
  id        Int       @id @default(autoincrement())
  host      User      @relation("UserHostedGameSessions", fields: [hostId], references: [id])
  hostId    Int
  project   Project   @relation(fields: [projectId], references: [id])
  projectId Int
  startedAt DateTime  @default(now())
  endedAt   DateTime?

  title      String
  maxPlayers Int
  visibility GameSessionVisibility @default(PUBLIC)
  otherUsers User[]                @relation("UserJoinedGameSessions")

  // Short join code generated only for INVITE_CODE sessions
  joinCode  String? @unique
  sessionId String  @unique @default(uuid())

  @@index([hostId])
  @@index([projectId])
}

model WorkSession {
  id           Int      @id @default(autoincrement())
  users        User[]   @relation("WorkSessionUsers")
  host         User     @relation("WorkSessionHost", fields: [hostId], references: [id])
  hostId       Int
  project      Project  @relation(fields: [projectId], references: [id])
  projectId    Int      @unique
  startedAt    DateTime @default(now())
  lastSaveAt   DateTime @default(now())
  lastActiveAt DateTime @default(now())

  roomId String @unique @default(uuid())

  @@index([projectId])
  @@index([hostId])
}
