enum MonetizationType {
  NONE
  ADS
  PAID
}

enum ProjectStatus {
  IN_PROGRESS
  COMPLETED
  ARCHIVED
}

enum ReportTargetType {
  USER
  PROJECT
  COMMENT
}

enum ReportStatus {
  OPEN
  IN_REVIEW
  RESOLVED
  DISMISSED
}

enum ModerationTargetType {
  USER
  PROJECT
  COMMENT
  REPORT
}

enum ModerationActionType {
  SUSPEND_USER
  BAN_USER
  RESTORE_USER
  HIDE_PROJECT
  RESTORE_PROJECT
  UNPUBLISH_PROJECT
  HIDE_COMMENT
  RESTORE_COMMENT
  REVIEW_REPORT
  RESOLVE_REPORT
  DISMISS_REPORT
  ANONYMIZE_USER
  HARD_DELETE_USER
  CREATE_STAFF_USER
  UPDATE_ROLES
  EDIT_USER
  EDIT_PROJECT
  EDIT_COMMENT
  UPDATE_REPORT
  RESET_PASSWORD
  CREATE_ROLE
  RENAME_ROLE
  DELETE_ROLE
}

enum AnalyticsEventType {
  ACCOUNT_CREATED
  LOGIN
  PROJECT_CREATED
  PROJECT_PUBLISHED
  PROJECT_UNPUBLISHED
  COMMENT_CREATED
  COMMENT_REPLIED
  LIKE_CREATED
  LIKE_REMOVED
  GAME_VIEWED
  GAME_SESSION_STARTED
  GAME_SESSION_ENDED
  WORK_SESSION_STARTED
  WORK_SESSION_JOINED
  WORK_SESSION_LEFT
}

model Project {
  id           Int               @id @default(autoincrement())
  name         String
  shortDesc    String
  longDesc     String?
  tags         String[]          @default([])
  publishedName      String?
  publishedShortDesc String?
  publishedLongDesc  String?
  publishedTags      String[]          @default([])
  status       ProjectStatus?    @default(IN_PROGRESS)
  iconUrl      String?
  monetization MonetizationType? @default(NONE)
  price        Float?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  publishedAt  DateTime?
  userId       Int

  contentKey        String?   @map("content_key")
  contentExtension  String?   @map("content_extension")
  contentUploadedAt DateTime? @map("content_uploaded_at")

  forkedFromId Int?      @map("forked_from_id")
  hidden       Boolean   @default(false)
  hiddenReason String?
  hiddenAt     DateTime?
  hiddenById   Int?      @map("hidden_by_id")

  // Relations
  forkedFrom    Project?      @relation("ProjectForks", fields: [forkedFromId], references: [id], onDelete: SetNull)
  forks         Project[]     @relation("ProjectForks")
  creator       User          @relation("ProjectCreator", fields: [userId], references: [id])
  collaborators User[]        @relation("ProjectCollaborators")
  comments      Comment[]
  gameSessions  GameSession[]
  workSession   WorkSession?
  userLikes     Like[]

  // Aggregate statistics
  viewCount     Int @default(0)
  uniquePlayers Int @default(0)
  activePlayers Int @default(0)
  likes         Int @default(0)
}

model Comment {
  id        Int       @id @default(autoincrement())
  author    User      @relation(fields: [authorId], references: [id])
  authorId  Int
  project   Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId Int
  parentId  Int?
  parent    Comment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies   Comment[] @relation("CommentReplies")
  content   String
  deleted   Boolean   @default(false)
  hidden    Boolean   @default(false)
  hiddenReason String?
  hiddenAt DateTime?
  hiddenById Int?     @map("hidden_by_id")
  createdAt DateTime  @default(now())

  @@index([projectId])
  @@index([authorId])
}

model Like {
  id        Int      @id @default(autoincrement())
  user      User     @relation(fields: [userId], references: [id])
  userId    Int
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId Int
  createdAt DateTime @default(now())

  @@unique([userId, projectId])
  @@index([projectId])
}

model Report {
  id             Int              @id @default(autoincrement())
  targetType     ReportTargetType
  targetId       Int
  reporter       User             @relation("ReportReporter", fields: [reporterId], references: [id], onDelete: Cascade)
  reporterId     Int
  reason         String
  details        String?
  status         ReportStatus     @default(OPEN)
  resolutionNote String?
  resolvedAt     DateTime?
  resolvedById   Int?             @map("resolved_by_id")
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  moderationActions ModerationAction[]

  @@index([targetType, targetId])
  @@index([reporterId])
  @@index([status])
  @@index([createdAt])
}

model ModerationAction {
  id         Int                  @id @default(autoincrement())
  actor      User?                @relation("ModerationActor", fields: [actorId], references: [id], onDelete: SetNull)
  actorId    Int?
  targetType ModerationTargetType
  targetId   Int
  action     ModerationActionType
  reason     String?
  before     Json?
  after      Json?
  report     Report?              @relation(fields: [reportId], references: [id], onDelete: SetNull)
  reportId   Int?
  createdAt  DateTime             @default(now())

  @@index([actorId])
  @@index([targetType, targetId])
  @@index([action])
  @@index([createdAt])
}

model AnalyticsEvent {
  id        Int                @id @default(autoincrement())
  type      AnalyticsEventType
  user      User?              @relation("AnalyticsActor", fields: [userId], references: [id], onDelete: SetNull)
  userId    Int?
  projectId Int?
  commentId Int?
  metadata  Json?
  createdAt DateTime           @default(now())

  @@index([type])
  @@index([userId])
  @@index([projectId])
  @@index([commentId])
  @@index([createdAt])
}

model DailyAnalyticsRollup {
  id                  Int      @id @default(autoincrement())
  date                DateTime @db.Date
  accountsCreated     Int      @default(0)
  logins              Int      @default(0)
  projectsCreated     Int      @default(0)
  projectsPublished   Int      @default(0)
  projectsUnpublished Int      @default(0)
  commentsCreated     Int      @default(0)
  likesCreated        Int      @default(0)
  likesRemoved        Int      @default(0)
  gameViews           Int      @default(0)
  gameSessionsStarted Int      @default(0)
  gameSessionsEnded   Int      @default(0)
  workSessionsStarted Int      @default(0)
  workSessionsJoined  Int      @default(0)
  workSessionsLeft    Int      @default(0)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@unique([date])
}
